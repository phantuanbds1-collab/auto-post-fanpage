# Airtable - lấy tại: airtable.com > Profile > Developer hub > Personal access tokens
AIRTABLE_TOKEN=your_airtable_personal_access_token

# Anthropic Claude - lấy tại: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# Facebook Page Access Token - lấy tại: developers.facebook.com > Graph API Explorer
# Chọn Page Access Token (không phải User Token)
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# Facebook Page ID - tìm trong phần About của Fan Page hoặc Graph API Explorer
FACEBOOK_PAGE_ID=your_facebook_page_id
